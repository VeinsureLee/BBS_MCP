# BBS_MCP — unified environment template.
# Copy this to `.env` (which is gitignored) and fill in your own values.
# `scripts/run.mjs` loads this file at the project root before spawning any
# workspace command (crawler init, MCP server, etc.), so a single .env at
# this level governs the whole monorepo.

# -- BBS adapter credentials -----------------------------------------------
# These map to whichever site adapter your crawler config (config/sites/*.yml)
# uses. The default `school-bbs` adapter reads SCHOOL_BBS_*.
SCHOOL_BBS_USERNAME=
SCHOOL_BBS_PASSWORD=
SCHOOL_BBS_BASE_URL=https://your.school.bbs.url

# -- Crawler runtime -------------------------------------------------------
# Where SQLite databases live (project-relative recommended for portability).
# Resolves relative to wherever the workspace script runs (typically BBS_Crawler/).
DATABASE_PATH=./data/crawler.db

# Where Playwright storageState (login cookies) is persisted.
STORAGE_STATE_DIR=./.state

# Headless mode. Set to `false` for the first login so you can see the browser.
BROWSER_HEADLESS=true

# Optional: path to your own Chrome/Chromium binary. If unset, Playwright uses
# its bundled Chromium installed by `npm run setup` into ./.cache/ms-playwright.
# BROWSER_EXECUTABLE_PATH=

# Optional: override user agent.
# BROWSER_USER_AGENT=

# -- Rate limiting ---------------------------------------------------------
# IDLE_TIMEOUT_MS=300000
# RATE_MIN_INTERVAL_MS=1500
# RATE_JITTER_MS=1000
# RATE_MAX_CONCURRENCY=1

# -- Logging ---------------------------------------------------------------
LOG_LEVEL=info

# -- Project-local Playwright browsers -------------------------------------
# Forces Playwright to use the project-local cache instead of ~/.cache.
# `npm run setup` sets this automatically when installing browsers; setting it
# here too makes any direct `npx playwright ...` invocation match.
PLAYWRIGHT_BROWSERS_PATH=./.cache/ms-playwright

# -- Graph layer (M4+; ignored for now) ------------------------------------
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
